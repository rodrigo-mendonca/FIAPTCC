    "service_dependencies": {
      "description": "Mapa de dependências entre serviços",
      "dependencies": [
        {
          "service": "calculo_juros_multa",
          "depends_on": ["update_contas_vencidas"],
          "reason": "Precisa que o status esteja atualizado antes de calcular juros"
        },
        {
          "service": "sincronizacao_saldo_clientes",
          "depends_on": ["calculo_juros_multa"],
          "reason": "Saldo deve ser calculado após aplicação de juros e multa"
        },
        {
          "service": "backup_diferencial",
          "conflicts_with": ["backup_database"],
          "reason": "Não devem executar simultaneamente para evitar lock de tabelas"
        },
        {
          "service": "sincronizacao_estoque_produtos",
          "depends_on": [],
          "reason": "Serviço independente disparado por trigger"
        },
        {
          "service": "otimizacao_indices_database",
          "conflicts_with": ["backup_database", "verificacao_integridade_dados"],
          "reason": "Operações pesadas não devem executar simultaneamente"
        },
        {
          "service": "consolidacao_dados_gerenciais",
          "depends_on": ["atualizacao_rankings_produtos", "calculo_comissoes_vendedores"],
          "reason": "Precisa de dados atualizados para consolidação"
        }
      ]
    },
