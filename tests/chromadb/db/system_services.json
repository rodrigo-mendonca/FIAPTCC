        "resources_required": {
          "disk_space": "10MB",
          "memory": "128MB",
          "cpu": "medium"
        },
        "business_logic": {
          "date_filter": "data_venda >= YESTERDAY AND data_venda < TODAY",
          "groupings": ["vendedor", "forma_pagamento", "categoria_produto"],
          "metrics": ["total_vendas", "qtd_vendas", "ticket_medio"]
        },
        "outputs": {
          "pdf_report": "vendas_diario_YYYYMMDD.pdf",
          "excel_file": "vendas_diario_YYYYMMDD.xlsx",
