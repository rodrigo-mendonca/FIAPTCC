    "services": {
      "backup_database": {
        "service_id": 1,
        "name": "Backup Automático da Base de Dados",
        "description": "Realiza backup completo de todas as tabelas do sistema comercial, incluindo dados e estrutura, armazenando em local seguro com compactação",
        "category": "backup",
        "status": "active",
        "execution_type": "scheduled",
        "schedule": {
          "frequency": "daily",
          "time": "02:00:00",
          "timezone": "America/Sao_Paulo",
          "description": "Executa diariamente às 2:00h da madrugada"
        },
        "estimated_duration": "15-30 minutos",
        "priority": "high",
        "dependencies": [],
        "resources_required": {
          "disk_space": "500MB",
          "memory": "256MB",
          "cpu": "low"
        },
        "inputs": {
          "backup_location": "/backup/daily/",
          "compression_level": "high",
          "retention_days": 30
        },
        "outputs": {
          "backup_file": "YYYYMMDD.sql.gz",
          "log_file": "backup_YYYYMMDD.log"
        },
        "notifications": {
          "on_success": "email_admin",
          "on_failure": "email_admin_urgent"
        },
        "last_execution": "2025-10-05T02:00:00Z",
        "next_execution": "2025-10-07T02:00:00Z"
      },
      "update_contas_vencidas": {
        "service_id": 2,
        "name": "Atualização de Status de Contas Vencidas",
        "description": "Verifica todas as contas a receber em aberto e atualiza automaticamente o status para 'vencida' quando a data de vencimento é ultrapassada",
        "category": "financeiro",
        "status": "active",
        "execution_type": "scheduled",
        "schedule": {
          "frequency": "daily",
          "time": "06:00:00",
          "timezone": "America/Sao_Paulo",
          "description": "Executa diariamente às 6:00h da manhã"
        },
        "estimated_duration": "2-5 minutos",
        "priority": "high",
        "dependencies": [],
        "resources_required": {
          "disk_space": "10MB",
          "memory": "64MB",
          "cpu": "low"
        },
        "business_logic": {
          "condition": "data_vencimento < CURRENT_DATE AND status = 'em_aberto'",
          "action": "UPDATE status = 'vencida'",
          "affected_table": "contas_receber"
        },
        "notifications": {
          "on_success": "log_only",
          "on_failure": "email_financeiro",
          "daily_report": "email_gerencia"
        },
        "metrics": {
          "contas_atualizadas": "integer",
          "valor_total_vencido": "decimal"
        }
      },
      "calculo_juros_multa": {
        "service_id": 3,
        "name": "Cálculo de Juros e Multa",
        "description": "Calcula e aplica juros de mora e multa por atraso nas contas vencidas conforme política comercial da empresa",
        "category": "financeiro",
        "status": "active",
        "execution_type": "scheduled",
        "schedule": {
          "frequency": "daily",
          "time": "06:30:00",
          "timezone": "America/Sao_Paulo",
          "description": "Executa diariamente às 6:30h, após atualização de status"
        },
        "estimated_duration": "5-10 minutos",
        "priority": "high",
        "dependencies": ["update_contas_vencidas"],
        "resources_required": {
          "disk_space": "20MB",
          "memory": "128MB",
          "cpu": "medium"
        },
        "business_logic": {
          "condition": "status = 'vencida' AND data_vencimento < CURRENT_DATE",
          "calculation": {
            "juros_diario": "0.033%",
            "multa_fixa": "2%",
            "formula": "(valor_original * 0.02) + (valor_original * 0.00033 * dias_atraso)"
          },
          "affected_table": "contas_receber",
          "updated_fields": ["juros_multa", "saldo_devedor"]
        },
        "notifications": {
          "on_success": "log_only",
          "on_failure": "email_financeiro",
          "weekly_report": "email_diretoria"
        }
      },
      "alerta_estoque_minimo": {
        "service_id": 4,
        "name": "Alerta de Estoque Mínimo",
        "description": "Monitora o estoque de todos os produtos ativos e gera alertas quando a quantidade atual fica igual ou abaixo do estoque mínimo configurado",
        "category": "estoque",
        "status": "active",
        "execution_type": "scheduled",
        "schedule": {
          "frequency": "daily",
          "time": "08:00:00",
          "timezone": "America/Sao_Paulo",
          "description": "Executa diariamente às 8:00h no início do expediente"
        },
        "estimated_duration": "1-3 minutos",
        "priority": "medium",
        "dependencies": [],
        "resources_required": {
          "disk_space": "5MB",
          "memory": "32MB",
          "cpu": "low"
        },
        "business_logic": {
          "condition": "estoque_atual <= estoque_minimo AND ativo = true",
          "action": "generate_alert",
          "affected_table": "produtos"
        },
        "notifications": {
          "on_products_found": "email_compras",
          "on_failure": "email_admin",
          "alert_level": "warning"
        },
        "outputs": {
          "report_file": "estoque_minimo_YYYYMMDD.csv",
          "email_subject": "Alerta: Produtos com estoque baixo"
        }
      },
      "sincronizacao_saldo_clientes": {
        "service_id": 5,
        "name": "Sincronização de Saldo dos Clientes",
        "description": "Recalcula e atualiza o saldo atual de todos os clientes baseado nas contas a receber em aberto, garantindo consistência dos dados",
        "category": "financeiro",
        "status": "active",
        "execution_type": "scheduled",
        "schedule": {
          "frequency": "daily",
          "time": "23:00:00",
          "timezone": "America/Sao_Paulo",
          "description": "Executa diariamente às 23:00h no final do expediente"
        },
        "estimated_duration": "10-20 minutos",
        "priority": "medium",
        "dependencies": ["calculo_juros_multa"],
        "resources_required": {
          "disk_space": "50MB",
          "memory": "256MB",
          "cpu": "medium"
        },
        "business_logic": {
          "calculation": "SUM(saldo_devedor) WHERE status IN ('em_aberto', 'vencida') GROUP BY id_cliente",
          "affected_table": "clientes",
          "updated_fields": ["saldo_atual"]
        },
        "notifications": {
          "on_success": "log_only",
          "on_failure": "email_admin",
          "on_discrepancies": "email_financeiro"
        }
      },
      "relatorio_vendas_diario": {
        "service_id": 6,
        "name": "Relatório de Vendas Diário",
        "description": "Gera relatório consolidado das vendas do dia anterior com totais por vendedor, forma de pagamento e categoria de produtos",
        "category": "relatorios",
        "status": "active",
        "execution_type": "scheduled",
        "schedule": {
          "frequency": "daily",
          "time": "07:00:00",
